<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProjectType>Library</ProjectType>
  </PropertyGroup>
  <Import Project="..\..\Shared.build.props" />
  <PropertyGroup>
    <AssemblyTitle>re-motion Code Generation (based on TypePipe)</AssemblyTitle>
    <AssemblyName>Remotion.Reflection.CodeGeneration.TypePipe</AssemblyName>
    <Description>Internal: Integrates Remotion.TypePipe and Remotion assemblies. (Note that Remotion.TypePipe does not depend on Remotion.)</Description>
    <RootNamespace>$(AssemblyName)</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="Schemas\TypePipeConfigurationSchema.xsd" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Core\Core.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Remotion.TypePipe" Version="3.0.0-x.9" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="System.Configuration" />
  </ItemGroup>
</Project>